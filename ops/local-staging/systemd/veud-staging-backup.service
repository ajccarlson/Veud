[Unit]
Description=Veud staging verified PostgreSQL backup
After=veud-staging-postgres.service
Requires=veud-staging-postgres.service
ConditionPathIsMountPoint=/media/sde
ConditionPathIsMountPoint=/media/sdd

[Service]
Type=oneshot
ExecStart=%h/Programs/Veud/ops/local-staging/run-backup.sh
Nice=10
IOSchedulingClass=idle
NoNewPrivileges=true
PrivateTmp=true
