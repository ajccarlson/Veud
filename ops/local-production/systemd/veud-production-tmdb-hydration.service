[Unit]
Description=Veud production TMDB catalog hydration
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
ExecStart=%h/Programs/Veud/ops/local-production/run-tmdb-hydration.sh
Restart=on-failure
RestartSec=60
TimeoutStopSec=90
Nice=10
CPUWeight=20
IOWeight=20
MemoryMax=750M
