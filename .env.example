# Local development and tests use the SQLite schema/client. PostgreSQL
# deployments replace DATABASE_URL with postgresql://... and must run
# `npm run prisma:generate:postgres` before building.
DATABASE_PATH="./prisma/data.db"
DATABASE_URL="file:./data.db?connection_limit=1"
CACHE_DATABASE_PATH="./other/cache.db"

# Optional backup overrides. BACKUP_OFFSITE_DIR must be a network-mounted or
# independently synced path to protect against failure of the application disk.
BACKUP_DB_PATH=""
BACKUP_DIR=""
BACKUP_KEEP="48"
BACKUP_VERIFY_USERNAME=""
BACKUP_OFFSITE_DIR=""
BACKUP_OFFSITE_KEEP="48"

# Required after a PostgreSQL cutover. Verification destroys/recreates the
# public schema of this clearly named disposable database on every backup.
POSTGRES_BACKUP_VERIFY_URL=""
# Optional receipt path when manually re-running `db:verify-backup:postgres`.
# The normal default is beside the verified archive.
POSTGRES_BACKUP_RECEIPT=""
PG_DUMP_BIN="pg_dump"
PG_RESTORE_BIN="pg_restore"
PSQL_BIN="psql"

SESSION_SECRET="REDACTED"
HONEYPOT_SECRET="REDACTED"
INTERNAL_COMMAND_TOKEN="REDACTED"
RESEND_API_KEY="REDACTED"
SENTRY_DSN="your-dsn"

TMDB_API_KEY="REDACTED"

TRAKT_API_KEY="REDACTED"
TRAKT_CLIENT_SECRET="REDACTED"
TRAKT_ACCESS_TOKEN_MAIN="REDACTED"
TRAKT_ACCESS_TOKEN_BACKUP="REDACTED"

MAL_CLIENT_ID="REDACTED"
MAL_CLIENT_SECRET="REDACTED"
MAL_USER="REDACTED"
# Non-secret documented authorization reference required by committed MAL jobs.
MAL_CATALOG_POLICY_APPROVAL_REF=""

ANILIST_CLIENT_ID="REDACTED"
ANILIST_CLIENT_SECRET="REDACTED"

# Optional. Enables the advanced catalog-bound "Tip of My Tongue" search.
OPENAI_API_KEY=""
OPENAI_TIP_OF_TONGUE_MODEL="gpt-5.6-luna"

# the mocks and some code rely on these two being prefixed with "MOCK_"
# if they aren't then the real github api will be attempted
GITHUB_CLIENT_ID="MOCK_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="MOCK_GITHUB_CLIENT_SECRET"
GITHUB_TOKEN="REDACTED"
